# 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ============================================
# AI 服务配置
# ============================================
# OpenRouter API 密钥
# 获取地址: https://openrouter.ai/keys
AI_API_KEY=sk-or-v1-your-actual-api-key-here

# ============================================
# Cloudflare R2 存储配置
# ============================================
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=your-access-key-here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key-here
CLOUDFLARE_R2_BUCKET_NAME=maxtwice-images
CLOUDFLARE_R2_PUBLIC_DOMAIN=https://images.maxtwice.com

# ============================================
# 数据库配置（可选，如需覆盖默认配置）
# ============================================
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/learn
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=your-password

# ============================================
# Redis 配置（可选）
# ============================================
# SPRING_REDIS_HOST=localhost
# SPRING_REDIS_PORT=6379
# SPRING_REDIS_PASSWORD=

# ============================================
# 邮件服务配置（可选）
# ============================================
# SPRING_MAIL_HOST=smtp.126.com
# SPRING_MAIL_PORT=465
# SPRING_MAIL_USERNAME=your-email@126.com
# SPRING_MAIL_PASSWORD=your-mail-password
