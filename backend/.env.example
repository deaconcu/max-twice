# 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ============================================
# 服务端口
# ============================================
PORT=9202

# ============================================
# 数据库配置
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USERNAME=root
DB_PASSWORD=your_password

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_password

# ============================================
# 邮件服务配置
# ============================================
MAIL_HOST=smtp.126.com
MAIL_PORT=465
MAIL_USERNAME=your_email@126.com
MAIL_PASSWORD=your_auth_code
MAIL_DEBUG=false

# ============================================
# Meilisearch 搜索服务
# ============================================
MEILISEARCH_ENABLED=false
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_api_key

# ============================================
# Milvus 向量数据库
# ============================================
MILVUS_ENABLED=true
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ============================================
# AI 服务配置
# ============================================
# OpenRouter API 密钥 (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_api_key

# Gemini API 密钥 (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key

# ============================================
# Cloudflare R2 存储配置
# ============================================
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=max-twice-images
CLOUDFLARE_R2_PUBLIC_DOMAIN=https://images.maxtwice.com

# ============================================
# Log
# ============================================
LOGGING_FILE_NAME=/var/log/twicemax/app.log
LOGGING_LOGBACK_ROLLINGPOLICY_MAX_FILE_SIZE=50MB
LOGGING_LOGBACK_ROLLINGPOLICY_MAX_HISTORY=30
LOGGING_LOGBACK_ROLLINGPOLICY_TOTAL_SIZE_CAP=1GB