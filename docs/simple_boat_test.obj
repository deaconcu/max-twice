# 简单船体测试模型
# Simple Boat Hull Test

# 一个简单的盒子形船体，用于验证概念
# 船应该是：底部低，侧壁向上，可以装水

# === 外部顶点 ===
# 外底四个角（Y=0，最低）
v -2.0 0.0 5.0    # 1 左前底
v 2.0 0.0 5.0     # 2 右前底
v 2.0 0.0 -5.0    # 3 右后底
v -2.0 0.0 -5.0   # 4 左后底

# 外顶四个角（Y=3，最高）
v -2.5 3.0 5.5    # 5 左前顶（向外扩张）
v 2.5 3.0 5.5     # 6 右前顶
v 2.5 3.0 -5.5    # 7 右后顶
v -2.5 3.0 -5.5   # 8 左后顶

# === 内部顶点 ===
# 内底四个角（Y=0.2，比外底略高）
v -1.8 0.2 4.8    # 9 左前内底
v 1.8 0.2 4.8     # 10 右前内底
v 1.8 0.2 -4.8    # 11 右后内底
v -1.8 0.2 -4.8   # 12 左后内底

# 内顶四个角（Y=3，与外顶同高但更靠内）
v -2.3 3.0 5.3    # 13 左前内顶
v 2.3 3.0 5.3     # 14 右前内顶
v 2.3 3.0 -5.3    # 15 右后内顶
v -2.3 3.0 -5.3   # 16 左后内顶

# === 面定义 ===

# --- 外部面（从外看） ---
# 外底
f 1 2 3
f 1 3 4

# 外部四个侧面
# 前面
f 1 5 2
f 2 5 6
# 右面
f 2 6 3
f 3 6 7
# 后面
f 3 7 4
f 4 7 8
# 左面
f 4 8 1
f 1 8 5

# --- 内部面（从内看） ---
# 内底（法线向上，朝向船内）
f 9 11 10
f 9 12 11

# 内部四个侧面（法线向内）
# 前面
f 9 10 13
f 10 14 13
# 右面
f 10 11 14
f 11 15 14
# 后面
f 11 12 15
f 12 16 15
# 左面
f 12 9 16
f 9 13 16

# --- 顶部边缘（连接内外） ---
# 前边
f 5 13 6
f 6 13 14
# 右边
f 6 14 7
f 7 14 15
# 后边
f 7 15 8
f 8 15 16
# 左边
f 8 16 5
f 5 16 13