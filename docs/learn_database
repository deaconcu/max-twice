  KEY `idx_message_system` (`sender_id`,`receiver_id`,`type`,`id` DESC),
  KEY `idx_message_category` (`receiver_id`,`category`,`id` DESC)
) ENGINE=InnoDB AUTO_INCREMENT=735 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;

CREATE TABLE `node` (
