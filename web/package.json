{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky",
    "test:e2e": "playwright test --config=tests/playwright/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=tests/playwright/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=tests/playwright/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=tests/playwright/playwright.config.ts --debug"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@tiptap/extension-code-block-lowlight": "^3.10.5",
    "@tiptap/extension-color": "^3.10.7",
    "@tiptap/extension-highlight": "^3.10.7",
    "@tiptap/extension-image": "^3.10.5",
    "@tiptap/extension-link": "^3.10.5",
    "@tiptap/extension-placeholder": "^3.10.5",
    "@tiptap/extension-subscript": "^3.10.7",
    "@tiptap/extension-superscript": "^3.10.7",
    "@tiptap/extension-table": "^3.10.7",
    "@tiptap/extension-table-cell": "^3.10.7",
    "@tiptap/extension-table-header": "^3.10.7",
    "@tiptap/extension-table-row": "^3.10.7",
    "@tiptap/extension-text-align": "^3.10.7",
    "@tiptap/extension-text-style": "^3.10.7",
    "@tiptap/extension-underline": "^3.10.7",
    "@tiptap/starter-kit": "^3.10.5",
    "@tiptap/vue-3": "^3.10.5",
    "@types/dagre": "^0.7.53",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.47.0",
    "@vue-flow/minimap": "^1.5.4",
    "axios": "^1.13.2",
    "dagre": "^0.8.5",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.25",
    "lowlight": "^3.3.0",
    "mermaid": "^11.12.1",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "sass": "^1.93.3",
    "vue": "^3.5.22",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.3",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.10.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.1.7",
    "vite-plugin-vuetify": "^2.1.2",
    "vue-tsc": "^3.1.0"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,scss}": [
      "prettier --write"
    ]
  }
}
